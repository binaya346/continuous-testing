# SonarQube Configuration
SONAR_VERSION=community
SONAR_PORT=9000

# Database Configuration
POSTGRES_USER=sonar
POSTGRES_PASSWORD=sonar_production_password_change_me
POSTGRES_DB=sonarqube

# Resource Limits (Java Heap)
# Recommended at least 2G for production, but can be adjusted for local teaching
SONAR_WEB_JAVA_OPTS="-Xmx512m -Xms512m -XX:+HeapDumpOnOutOfMemoryError"
SONAR_CE_JAVA_OPTS="-Xmx512m -Xms512m -XX:+HeapDumpOnOutOfMemoryError"
SONAR_SEARCH_JAVA_OPTS="-Xmx512m -Xms512m -XX:+HeapDumpOnOutOfMemoryError"
